<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TechStoreApp.Views.AdminPanelPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TechStoreApp.Views"
    xmlns:vm="using:TechStoreApp.ViewModels"
    xmlns:models="using:TechStoreApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:AdminViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid Padding="20">
        <Pivot Title="Panel Administratora">
            <PivotItem Header="Produkty">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                            <AutoSuggestBox PlaceholderText="Szukaj produktów..." 
                                            Text="{Binding ProductSearchText, Mode=TwoWay}" 
                                            Width="250" 
                                            QueryIcon="Find" />
                            <TextBlock Text="Sortuj:" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <ComboBox ItemsSource="{Binding SortOptions}" 
                                      SelectedItem="{Binding SelectedSort, Mode=TwoWay}" 
                                      Width="180" />
                        </StackPanel>

                        <ListView Grid.Row="1" ItemsSource="{Binding Products}" 
                                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Product">
                                    <Grid Padding="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Sku}" Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Price, Converter={StaticResource PriceConverter}}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <StackPanel Grid.Column="1" Spacing="10" Padding="10" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4">
                        <TextBlock Text="Szczegóły Produktu" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBox Header="Nazwa" Text="{Binding EditProductName, Mode=TwoWay}" />
                        <TextBox Header="SKU" Text="{Binding EditProductSku, Mode=TwoWay}" />
                        <NumberBox Header="Cena" Value="{Binding EditProductPrice, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                        <NumberBox Header="Stan magazynowy" Value="{Binding EditProductStock, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                        <ComboBox Header="Kategoria" ItemsSource="{Binding Categories}" 
                                  SelectedItem="{Binding SelectedEditCategory, Mode=TwoWay}"
                                  DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                        
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <Button Content="Zapisz" Command="{Binding SaveProductCommand}" Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Dodaj nowy" Command="{Binding AddProductCommand}" />
                            <Button Content="Usuń" Command="{Binding DeleteProductCommand}" Foreground="Red" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </PivotItem>

            <PivotItem Header="Użytkownicy">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="400" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <AutoSuggestBox Grid.Row="0" 
                                        PlaceholderText="Szukaj użytkowników (email, imię...)" 
                                        Text="{Binding UserSearchText, Mode=TwoWay}" 
                                        QueryIcon="Find" 
                                        Margin="0,0,0,10" />

                        <ListView Grid.Row="1" ItemsSource="{Binding Users}" 
                                  SelectedItem="{Binding SelectedUser, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Customer">
                                    <Grid Padding="0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Email}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind FirstName}" Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <SymbolIcon Symbol="Admin" Visibility="{x:Bind IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Reset Hasła" Command="{Binding DataContext.ResetPasswordCommand, ElementName=PageRoot}" CommandParameter="{x:Bind}" />
                                            <Button Content="Usuń" Command="{Binding DataContext.DeleteUserCommand, ElementName=PageRoot}" CommandParameter="{x:Bind}" Foreground="Red" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <Grid Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4" Padding="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Szczegóły i Zamówienia" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,10" />
                        
                        <StackPanel Grid.Row="1" Spacing="5" Margin="0,0,0,20">
                            <TextBlock Text="{Binding SelectedUser.Email, Converter={StaticResource StringFormatConverter}, ConverterParameter='Użytkownik: {0}'}" FontWeight="Bold" />
                            <Button Content="Przełącz Uprawnienia Admina" 
                                    Command="{Binding ToggleAdminCommand}" 
                                    CommandParameter="{Binding SelectedUser}"
                                    HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <ListView Grid.Row="2" ItemsSource="{Binding UserOrders}" SelectionMode="None">
                            <ListView.Header>
                                <TextBlock Text="Historia Zamówień" FontWeight="Bold" Margin="0,0,0,10" />
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Order">
                                    <Expander HorizontalAlignment="Stretch" Margin="0,0,0,10">
                                        <Expander.Header>
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind OrderDate}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind TotalAmount, Converter={StaticResource PriceConverter}}" FontWeight="Bold" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Usuń" 
                                                        Command="{Binding DataContext.DeleteOrderCommand, ElementName=PageRoot}" 
                                                        CommandParameter="{x:Bind}" Foreground="Red" 
                                                        Style="{StaticResource SubtleButtonStyle}"/>
                                            </Grid>
                                        </Expander.Header>
                                        <StackPanel Spacing="5" Padding="10">
                                            <TextBlock Text="Produkty:" FontWeight="Bold" />
                                            <ItemsControl ItemsSource="{x:Bind OrderDetails}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:OrderDetail">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{x:Bind Product.Name}" />
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                                                <TextBlock Text="{x:Bind Quantity}" />
                                                                <TextBlock Text="x" />
                                                                <TextBlock Text="{x:Bind UnitPrice, Converter={StaticResource PriceConverter}}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Border BorderThickness="0,1,0,0" BorderBrush="Gray" Margin="0,5" />
                                            <TextBlock Text="{x:Bind ShippingMethod, Converter={StaticResource StringFormatConverter}, ConverterParameter='Dostawa: {0}'}" />
                                            <TextBlock Text="{x:Bind ShippingAddress}" />
                                        </StackPanel>
                                    </Expander>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TechStoreApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TechStoreApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TechStoreApp">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <Storyboard x:Name="PopStoryboard">
                <DoubleAnimation Storyboard.TargetName="CartBadgeScale" 
                                 Storyboard.TargetProperty="ScaleX"
                                 From="1.0" To="1.4" Duration="0:0:0.1" AutoReverse="True">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="CartBadgeScale" 
                                 Storyboard.TargetProperty="ScaleY"
                                 From="1.0" To="1.4" Duration="0:0:0.1" AutoReverse="True">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="45" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" VerticalAlignment="Stretch" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="Tech Store" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView" 
                        Grid.Row="1"
                        Loaded="NavView_Loaded"
                        ItemInvoked="NavView_ItemInvoked"
                        IsBackButtonVisible="Collapsed"
                        PaneDisplayMode="Auto">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="catalog" Icon="Shop" Content="Sklep" />
                <NavigationViewItem x:Name="CartNavItem" Tag="cart" Icon="OutlineStar" Content="Koszyk">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="CartBadge" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <InfoBadge.RenderTransform>
                                <ScaleTransform x:Name="CartBadgeScale" />
                            </InfoBadge.RenderTransform>
                        </InfoBadge>
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
                <NavigationViewItem Tag="orders" Icon="Library" Content="Moje Zamówienia" />
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="AdminNavItem" Tag="admin" Icon="Admin" Content="Panel Administratora" Visibility="Collapsed" />
                <NavigationViewItem x:Name="LoginNavItem" Tag="login" Icon="Contact" Content="Zaloguj się / Rejestracja" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Padding="20" />
        </NavigationView>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TechStoreApp.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TechStoreApp.Views"
    xmlns:vm="using:TechStoreApp.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:AccountViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <ScrollViewer>
        <Grid Padding="40" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Moje Konto" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,30" />

            <!-- Sekcja: Dane osobowe -->
            <StackPanel Grid.Row="1" Spacing="15" Margin="0,0,0,30" Padding="20" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                <TextBlock Text="Dane osobowe" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="{Binding Email, Converter={StaticResource StringFormatConverter}, ConverterParameter='Zalogowany jako: {0}'}" Style="{StaticResource CaptionTextBlockStyle}" />
                
                <TextBox Header="Imię" Text="{Binding FirstName, Mode=TwoWay}" />
                <TextBox Header="Nazwisko" Text="{Binding LastName, Mode=TwoWay}" />
                <Button Content="Zaktualizuj dane" Command="{Binding UpdateInfoCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>

            <!-- Sekcja: Bezpieczeństwo -->
            <StackPanel Grid.Row="2" Spacing="15" Padding="20" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                <TextBlock Text="Bezpieczeństwo" Style="{StaticResource SubtitleTextBlockStyle}" />
                <PasswordBox Header="Stare hasło" Password="{Binding OldPassword, Mode=TwoWay}" />
                <PasswordBox Header="Nowe hasło" Password="{Binding NewPassword, Mode=TwoWay}" />
                <Button Content="Zmień hasło" Command="{Binding ChangePasswordCommand}" HorizontalAlignment="Stretch" />
                
                <TextBlock Text="{Binding Message}" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" Margin="0,10,0,0" />

                <Border BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,10" />

                <Button Content="Wyloguj się" Command="{Binding LogoutCommand}" 
                        HorizontalAlignment="Stretch" Foreground="Red" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

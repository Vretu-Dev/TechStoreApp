<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="TechStoreApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TechStoreApp"
    xmlns:conv="using:TechStoreApp.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:LoginTitleConverter x:Key="LoginTitleConverter" />
            <conv:LoginToggleConverter x:Key="LoginToggleConverter" />
            <conv:PriceConverter x:Key="PriceConverter" />
            <conv:StringFormatConverter x:Key="StringFormatConverter" />
            
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>

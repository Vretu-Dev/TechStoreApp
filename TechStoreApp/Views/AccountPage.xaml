<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TechStoreApp.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TechStoreApp.Views"
    xmlns:vm="using:TechStoreApp.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:AccountViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
        <StackPanel Spacing="20" Padding="30" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
            <TextBlock Text="Moje Konto" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
            
            <StackPanel Spacing="5">
                <TextBlock Text="{Binding FullName}" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Email}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
            </StackPanel>

            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <TextBlock Text="Zmień hasło" Style="{StaticResource SubtitleTextBlockStyle}" />
            <PasswordBox Header="Stare hasło" Password="{Binding OldPassword, Mode=TwoWay}" />
            <PasswordBox Header="Nowe hasło" Password="{Binding NewPassword, Mode=TwoWay}" />
            <Button Content="Zmień hasło" Command="{Binding ChangePasswordCommand}" HorizontalAlignment="Stretch" />
            
            <TextBlock Text="{Binding Message}" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />

            <Button Content="Wyloguj się" Command="{Binding LogoutCommand}" 
                    HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>

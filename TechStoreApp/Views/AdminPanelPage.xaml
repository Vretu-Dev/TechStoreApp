<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TechStoreApp.Views.AdminPanelPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TechStoreApp.Views"
    xmlns:vm="using:TechStoreApp.ViewModels"
    xmlns:models="using:TechStoreApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:AdminViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid Padding="20">
        <Pivot Title="Panel Administratora">
            <PivotItem Header="Produkty">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <ListView Grid.Column="0" ItemsSource="{Binding Products}" 
                              SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                              Margin="0,0,20,0">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Product">
                                <Grid Padding="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind Sku}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Price, Converter={StaticResource PriceConverter}}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Column="1" Spacing="10" Padding="10" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4">
                        <TextBlock Text="Szczegóły Produktu" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBox Header="Nazwa" Text="{Binding EditProductName, Mode=TwoWay}" />
                        <TextBox Header="SKU" Text="{Binding EditProductSku, Mode=TwoWay}" />
                        <NumberBox Header="Cena" Value="{Binding EditProductPrice, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                        <NumberBox Header="Stan magazynowy" Value="{Binding EditProductStock, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                        <ComboBox Header="Kategoria" ItemsSource="{Binding Categories}" 
                                  SelectedItem="{Binding SelectedEditCategory, Mode=TwoWay}"
                                  DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                        
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <Button Content="Zapisz" Command="{Binding SaveProductCommand}" Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Dodaj nowy" Command="{Binding AddProductCommand}" />
                            <Button Content="Usuń" Command="{Binding DeleteProductCommand}" Foreground="Red" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </PivotItem>

            <PivotItem Header="Użytkownicy">
                <ListView ItemsSource="{Binding Users}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Customer">
                            <Grid Padding="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Email}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind FirstName}" Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Content="Administrator" IsChecked="{x:Bind IsAdmin, Mode=OneWay}" IsEnabled="False" VerticalAlignment="Center" Margin="0,0,20,0" />
                                <Button Grid.Column="2" Content="Przełącz uprawnienia" 
                                        Command="{Binding DataContext.ToggleAdminCommand, ElementName=PageRoot}" 
                                        CommandParameter="{x:Bind}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>

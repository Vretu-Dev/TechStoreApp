<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TechStoreApp.Views.AdminPanelPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TechStoreApp.Views"
    xmlns:vm="using:TechStoreApp.ViewModels"
    xmlns:models="using:TechStoreApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:AdminViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid Padding="20">
        <Pivot Title="Panel Administratora">
            <PivotItem Header="Produkty">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                            <AutoSuggestBox PlaceholderText="Szukaj produktów..." 
                                            Text="{Binding ProductSearchText, Mode=TwoWay}" 
                                            Width="250" 
                                            QueryIcon="Find" />
                            <TextBlock Text="Sortuj:" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <ComboBox ItemsSource="{Binding SortOptions}" 
                                      SelectedItem="{Binding SelectedSort, Mode=TwoWay}" 
                                      Width="180" />
                        </StackPanel>

                        <ListView Grid.Row="1" ItemsSource="{Binding Products}" 
                                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Product">
                                    <Grid Padding="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Sku}" Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Price, Converter={StaticResource PriceConverter}}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <ScrollViewer Grid.Column="1" Padding="10" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Szczegóły Produktu" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBox Header="Nazwa" Text="{Binding EditProductName, Mode=TwoWay}" />
                            <TextBox Header="SKU" Text="{Binding EditProductSku, Mode=TwoWay}" />
                            <NumberBox Header="Cena" Value="{Binding EditProductPrice, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                            <NumberBox Header="Stan magazynowy" Value="{Binding EditProductStock, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                            <ComboBox Header="Kategoria" ItemsSource="{Binding Categories}" 
                                      SelectedItem="{Binding SelectedEditCategory, Mode=TwoWay}"
                                      DisplayMemberPath="Name" HorizontalAlignment="Stretch" />

                            <TextBox Header="Opis" Text="{Binding EditProductDescription, Mode=TwoWay}" 
                                     TextWrapping="Wrap" AcceptsReturn="True" Height="100" />

                            <TextBlock Text="Specyfikacja (Atrybuty)" FontWeight="Bold" Margin="0,10,0,0" />
                            <ItemsControl ItemsSource="{Binding EditProductAttributes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ProductAttribute">
                                        <Grid ColumnSpacing="10" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" PlaceholderText="Cecha" Text="{x:Bind KeyName, Mode=TwoWay}" />
                                            <TextBox Grid.Column="1" PlaceholderText="Wartość" Text="{x:Bind Value, Mode=TwoWay}" />
                                            <Button Grid.Column="2" Content="X" 
                                                    Command="{Binding DataContext.RemoveEditAttributeCommand, ElementName=PageRoot}" 
                                                    CommandParameter="{x:Bind}" Foreground="Red" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Dodaj Atrybut" Command="{Binding AddEditAttributeCommand}" HorizontalAlignment="Stretch" />

                            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" />

                            <StackPanel Orientation="Vertical" Spacing="10" Margin="0,10,0,0">
                                <Button Content="Zapisz Zmiany" Command="{Binding SaveProductCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Kreator" Command="{Binding OpenWizardCommand}" HorizontalAlignment="Stretch" />
                                    <Button Grid.Column="1" Content="Usuń" Command="{Binding DeleteProductCommand}" Foreground="Red" HorizontalAlignment="Stretch" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </PivotItem>

            <PivotItem Header="Użytkownicy">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="400" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <AutoSuggestBox Grid.Row="0" 
                                        PlaceholderText="Szukaj użytkowników (email, imię...)" 
                                        Text="{Binding UserSearchText, Mode=TwoWay}" 
                                        QueryIcon="Find" 
                                        Margin="0,0,0,10" />

                        <ListView Grid.Row="1" ItemsSource="{Binding Users}" 
                                  SelectedItem="{Binding SelectedUser, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Customer">
                                    <Grid Padding="0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Email}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind FirstName}" Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <SymbolIcon Symbol="Admin" Visibility="{x:Bind IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Reset Hasła" Command="{Binding DataContext.ResetPasswordCommand, ElementName=PageRoot}" CommandParameter="{x:Bind}" />
                                            <Button Content="Usuń" Command="{Binding DataContext.DeleteUserCommand, ElementName=PageRoot}" CommandParameter="{x:Bind}" Foreground="Red" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <Grid Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4" Padding="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Szczegóły i Zamówienia" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,10" />
                        
                        <StackPanel Grid.Row="1" Spacing="5" Margin="0,0,0,20">
                            <TextBlock Text="{Binding SelectedUser.Email, Converter={StaticResource StringFormatConverter}, ConverterParameter='Użytkownik: {0}'}" FontWeight="Bold" />
                            <Button Content="Przełącz Uprawnienia Admina" 
                                    Command="{Binding ToggleAdminCommand}" 
                                    CommandParameter="{Binding SelectedUser}"
                                    HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <ListView Grid.Row="2" ItemsSource="{Binding UserOrders}" SelectionMode="None">
                            <ListView.Header>
                                <TextBlock Text="Historia Zamówień" FontWeight="Bold" Margin="0,0,0,10" />
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Order">
                                    <Expander HorizontalAlignment="Stretch" Margin="0,0,0,10">
                                        <Expander.Header>
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind OrderDate}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind TotalAmount, Converter={StaticResource PriceConverter}}" FontWeight="Bold" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Usuń" 
                                                        Command="{Binding DataContext.DeleteOrderCommand, ElementName=PageRoot}" 
                                                        CommandParameter="{x:Bind}" Foreground="Red" 
                                                        Style="{StaticResource SubtleButtonStyle}"/>
                                            </Grid>
                                        </Expander.Header>
                                        <StackPanel Spacing="5" Padding="10">
                                            <Grid ColumnSpacing="10" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Status:" VerticalAlignment="Center" FontWeight="Bold" />
                                                <ComboBox Grid.Column="1" ItemsSource="{Binding DataContext.OrderStatuses, ElementName=PageRoot}"
                                                          SelectedItem="{Binding Status, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch">
                                                </ComboBox>
                                                <Button Grid.Column="2" Content="Zmień" 
                                                        Command="{Binding DataContext.ChangeOrderStatusCommand, ElementName=PageRoot}"
                                                        CommandParameter="{x:Bind}" />
                                            </Grid>
                                            
                                            <TextBlock Text="Produkty:" FontWeight="Bold" />
                                            <ItemsControl ItemsSource="{x:Bind OrderDetails}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:OrderDetail">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{x:Bind Product.Name}" />
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                                                <TextBlock Text="{x:Bind Quantity}" />
                                                                <TextBlock Text="x" />
                                                                <TextBlock Text="{x:Bind UnitPrice, Converter={StaticResource PriceConverter}}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Border BorderThickness="0,1,0,0" BorderBrush="Gray" Margin="0,5" />
                                            <TextBlock Text="{x:Bind ShippingMethod, Converter={StaticResource StringFormatConverter}, ConverterParameter='Dostawa: {0}'}" />
                                            <TextBlock Text="{x:Bind ShippingAddress}" />
                                            <ItemsControl ItemsSource="{x:Bind Shipments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:Shipment">
                                                        <StackPanel Margin="0,5,0,0">
                                                            <TextBlock Text="{x:Bind TrackingNumber, Converter={StaticResource StringFormatConverter}, ConverterParameter='Nr przesyłki: {0}'}" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" />
                                                            <TextBlock Text="{x:Bind ShippedDate, Converter={StaticResource StringFormatConverter}, ConverterParameter='Wysłano: {0}'}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </PivotItem>
            <PivotItem Header="Kategorie">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <ListView Grid.Column="0" ItemsSource="{Binding Categories}" 
                              SelectedItem="{Binding SelectedAdminCategory, Mode=TwoWay}"
                              Margin="0,0,20,0">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Category">
                                <StackPanel Padding="0,5">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ParentCategoryId, Converter={StaticResource StringFormatConverter}, ConverterParameter='ID Rodzica: {0}'}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="Gray" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Column="1" Spacing="10" Padding="10" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4">
                        <TextBlock Text="Szczegóły Kategorii" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBox Header="Nazwa" Text="{Binding EditCategoryName, Mode=TwoWay}" />
                        <TextBlock Text="Kategoria Nadrzędna" Style="{StaticResource BodyTextBlockStyle}" Margin="0,5,0,0"/>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Categories}" 
                                      SelectedItem="{Binding SelectedParentCategory, Mode=TwoWay}"
                                      DisplayMemberPath="Name" HorizontalAlignment="Stretch" 
                                      PlaceholderText="Brak (Kategoria główna)" />
                            <Button Grid.Column="1" Content="Wyczyść" Command="{Binding ClearParentCategoryCommand}" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <Button Content="Zapisz" Command="{Binding SaveCategoryCommand}" Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Dodaj nową" Command="{Binding AddCategoryCommand}" />
                            <Button Content="Usuń" Command="{Binding DeleteCategoryCommand}" Foreground="Red" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </PivotItem>
        </Pivot>

        <!-- Product Wizard Overlay -->
        <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" 
              Visibility="{Binding IsWizardOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              CornerRadius="8" Padding="30" Margin="20"
              HorizontalAlignment="Center" VerticalAlignment="Center" 
              Width="600" MaxHeight="800" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Kreator Produktu" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,20" />
            
            <ScrollViewer Grid.Row="1" Margin="0,0,0,20">
                <StackPanel Spacing="15" Padding="0,0,20,0">
                    <TextBox Header="Nazwa" Text="{Binding WizardName, Mode=TwoWay}" />
                    <TextBox Header="SKU" Text="{Binding WizardSku, Mode=TwoWay}" />
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <NumberBox Grid.Column="0" Header="Cena" Value="{Binding WizardPrice, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                        <NumberBox Grid.Column="1" Header="Stan magazynowy" Value="{Binding WizardStock, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                    </Grid>
                    <ComboBox Header="Kategoria" ItemsSource="{Binding Categories}" 
                              SelectedItem="{Binding WizardCategory, Mode=TwoWay}"
                              DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                              
                    <TextBox Header="Opis" Text="{Binding WizardDescription, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" Height="100" />
                    
                    <TextBlock Text="Specyfikacja (Atrybuty)" FontWeight="Bold" Margin="0,10,0,0" />
                    <ItemsControl ItemsSource="{Binding WizardAttributes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ProductAttribute">
                                <Grid ColumnSpacing="10" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" PlaceholderText="Cecha (np. Procesor)" Text="{x:Bind KeyName, Mode=TwoWay}" />
                                    <TextBox Grid.Column="1" PlaceholderText="Wartość (np. Intel i7)" Text="{x:Bind Value, Mode=TwoWay}" />
                                    <Button Grid.Column="2" Content="X" 
                                            Command="{Binding DataContext.RemoveWizardAttributeCommand, ElementName=PageRoot}" 
                                            CommandParameter="{x:Bind}" Foreground="Red" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="Dodaj Atrybut" Command="{Binding AddWizardAttributeCommand}" />
                    
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,10,0,0" />
                </StackPanel>
            </ScrollViewer>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Anuluj" Command="{Binding CloseWizardCommand}" />
                <Button Content="Zapisz Produkt" Command="{Binding SaveWizardCommand}" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>

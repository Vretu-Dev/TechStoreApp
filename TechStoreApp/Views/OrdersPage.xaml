<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TechStoreApp.Views.OrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TechStoreApp.Views"
    xmlns:vm="using:TechStoreApp.ViewModels"
    xmlns:models="using:TechStoreApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:OrdersViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Twoje Zamówienia" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,20" />

        <ListView Grid.Row="1" ItemsSource="{Binding Orders}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Order">
                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,10">
                        <Expander.Header>
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind OrderDate, Mode=OneWay}" Margin="0,0,20,0" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Status, Mode=OneWay}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="{x:Bind TotalAmount, Converter={StaticResource PriceConverter}}" FontWeight="Bold" />
                            </Grid>
                        </Expander.Header>
                        <Expander.Content>
                            <StackPanel Spacing="10">
                                <TextBlock Text="Szczegóły dostawy" FontWeight="Bold" Margin="0,5,0,0" />
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Dostawa:" />
                                    <TextBlock Text="{x:Bind ShippingMethod}" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind ShippingAddress}" />
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{x:Bind ShippingPostalCode}" />
                                    <TextBlock Text="{x:Bind ShippingCity}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Płatność:" />
                                    <TextBlock Text="{x:Bind PaymentMethod}" />
                                </StackPanel>

                                <ItemsControl ItemsSource="{x:Bind Shipments}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:Shipment">
                                            <StackPanel Margin="0,5,0,0">
                                                <TextBlock Text="{x:Bind TrackingNumber, Converter={StaticResource StringFormatConverter}, ConverterParameter='Nr przesyłki: {0}'}" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" />
                                                <TextBlock Text="{x:Bind ShippedDate, Converter={StaticResource StringFormatConverter}, ConverterParameter='Data wysyłki: {0:dd.MM.yyyy}'}" Style="{StaticResource CaptionTextBlockStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <TextBlock Text="Produkty" FontWeight="Bold" Margin="0,10,0,0" />
                                <ListView ItemsSource="{x:Bind OrderDetails}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:OrderDetail">
                                            <Grid Padding="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind Product.Name}" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Quantity}" />
                                                    <TextBlock Text="x" />
                                                    <TextBlock Text="{x:Bind UnitPrice, Converter={StaticResource PriceConverter}}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Expander.Content>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
